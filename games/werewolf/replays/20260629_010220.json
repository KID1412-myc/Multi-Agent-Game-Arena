发言找破绽。\n\n刀-p5。你们定吧，我没意见。", "target_id": "", "round": 1}}, {"t": 30.588092499994673, "type": "NIGHT_ACTION", "payload": {"action": "wolf_vote", "player_id": "p8", "player_name": "Kimi", "detail": "刀 p5(GOD)", "target_id": "p5", "round": 1}}, {"t": 32.63714590005111, "type": "NIGHT_ACTION", "payload": {"action": "wolf_vote", "player_id": "p3", "player_name": "豆包", "detail": "刀 p5(GOD)", "target_id": "p5", "round": 1}}, {"t": 33.429240399971604, "type": "NIGHT_ACTION", "payload": {"action": "wolf_vote", "player_id": "p7", "player_name": "Gemini2号", "detail": "刀 p5(GOD)", "target_id": "p5", "round": 1}}, {"t": 40.92327230004594, "type": "NIGHT_ACTION", "payload": {"action": "seer_check", "player_id": "p1", "player_name": "ChatGPT", "detail": "查验 p5(GOD) → 好人", "target_id": "p5", "round": 1}}, {"t": 46.22388970002066, "type": "NIGHT_ACTION", "payload": {"action": "witch_action", "player_id": "p5", "player_name": "GOD", "detail": "使用解药，救活 GOD(p5)", "target_id": "p5", "round": 1}}]}
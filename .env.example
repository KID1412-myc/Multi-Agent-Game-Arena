# ============================================
# MAGA — 多 Agent 博弈沙盒引擎
# API Key 配置文件（只负责鉴权，不管模型选择）
# ============================================
# 复制此文件为 .env 并填入你的 API Keys
#
# ┌─────────────────────────────────────────────┐
# │  模型选择在哪里？                            │
# │  → games/<游戏名>/config.json               │
# │  每个玩家的 "model" 字段决定用哪个模型         │
# │  "dm_model" 字段决定主裁判用哪个模型          │
# │  .env 只管鉴权，不管模型                     │
# └─────────────────────────────────────────────┘
#
# 💡 如果你用中转站：
#    只需填 RELAY_API_KEY 和 RELAY_API_BASE，
#    然后去 config.json 把所有 provider 改为 "relay"，
#    model 填你中转站支持的模型名（如 gpt-4o、claude-sonnet-4-6 等）

# ===== 中转站模式（推荐：一个 Key 走天下）=====
RELAY_API_KEY=sk-your-relay-key-here
RELAY_API_BASE=https://your-relay-api.com/v1

# ===== 直连模式（分别填写各厂商 Key）=====
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DOUBAO_API_KEY=your-doubao-key-here
MINIMAX_API_KEY=your-minimax-key-here
ZHIPU_API_KEY=your-zhipu-key-here
QWEN_API_KEY=sk-your-qwen-key-here
HUNYUAN_API_KEY=sk-your-hunyuan-key-here
# ============================================
# 服务器配置
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
FRONTEND_PORT=5173
